# RAG 知识库系统环境配置

# 认证配置 (重要! 公网访问必须设置)
# 设置为 false 可禁用认证（仅本地开发使用）
AUTH_ENABLED=true

# JWT 密钥 - 用于签名 token，生产环境必须设置为强随机字符串
# 可使用: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# 管理员用户名
ADMIN_USERNAME=admin

# 管理员密码 - 首次启动时自动哈希存储
# 生产环境必须设置强密码
ADMIN_PASSWORD=your-secure-password

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Ollama 配置
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=bge-m3
OLLAMA_EMBED_DIM=1024

# Qdrant 配置
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_PREFIX=project_

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# 数据目录
DATA_DIR=./data
PROJECTS_DIR=./data/projects
VECTOR_DB_DIR=./data/vector_db
DB_PATH=./db/metadata.db

# MinerU 配置
MINERU_DEVICE=mps
MINERU_CONFIG_PATH=~/.mineru/magic-pdf.json

# 分块配置
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
CHUNK_SEPARATORS=["\n\n", "\n", "。", "；", " "]

# 检索配置
SEARCH_TOP_K=10
SEARCH_SCORE_THRESHOLD=0.7
SEARCH_RERANK_TOP_K=5

# MCP 配置
MCP_SERVER_NAME=rag-knowledge-base
MCP_TRANSPORT=stdio
